{
    "name": "@v-face/sdk",
    "version": "1.0.0",
    "type": "module",
    "description": "Privacy-Preserving Biometric Identity for AI Agents",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./setup": {
            "import": "./setup.js",
            "types": "./setup.d.ts"
        },
        "./zk": {
            "import": "./zk/zkProof.js"
        },
        "./offline": {
            "import": "./offline/offlineVerify.js"
        },
        "./webauthn": {
            "import": "./useWebAuthn.js"
        },
        "./embedding": {
            "import": "./embedding/pipeline.js",
            "types": "./embedding/pipeline.d.ts"
        },
        "./fingerprint": {
            "import": "./fingerprint/index.js",
            "types": "./fingerprint/index.d.ts"
        },
        "./registry": {
            "import": "./registry/index.js",
            "types": "./registry/index.d.ts"
        }
    },
    "files": [
        "index.js",
        "index.d.ts",
        "setup.js",
        "setup.d.ts",
        "embedding/",
        "fingerprint/",
        "registry/",
        "liveness/",
        "zk/",
        "offline/",
        "useWebAuthn.js",
        "dist/",
        "README.md"
    ],
    "scripts": {
        "test": "mocha test/**/*.test.js",
        "test:integration": "mocha test/integration.test.js --timeout 10000",
        "robustness": "node test/run_robustness.js",
        "build": "tsup index.js --format esm,cjs --dts --clean --external react --external canvas",
        "build:types": "tsc --declaration --emitDeclarationOnly",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "biometric",
        "privacy",
        "consent",
        "identity",
        "web3",
        "blockchain"
    ],
    "author": "V-Face Contributors",
    "license": "GPL-3.0",
    "engines": {
        "node": ">=16.0.0"
    },
    "peerDependencies": {
        "react": "^18.0.0"
    },
    "dependencies": {
        "@simplewebauthn/browser": "^13.2.2",
        "circomlibjs": "^0.1.7",
        "ethers": "^6.10.0",
        "onnxruntime-web": "^1.21.0",
        "snarkjs": "^0.7.6"
    },
    "optionalDependencies": {
        "canvas": "^2.11.2",
        "face-api.js": "^0.22.2"
    },
    "devDependencies": {
        "@tensorflow/tfjs-node": "^4.22.0",
        "canvas": "^2.11.2",
        "chai": "^4.3.7",
        "jimp": "^0.22.10",
        "mocha": "^10.2.0",
        "node-fetch": "^3.3.2",
        "terser": "^5.24.0",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0",
        "vite": "^5.0.0"
    },
    "directories": {
        "test": "test"
    },
    "types": "./index.d.ts"
}
