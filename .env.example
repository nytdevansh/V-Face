# V-Face Environment Configuration

# ============================================================================
# API Service (Node.js)
# ============================================================================
PORT=3000
DATABASE_PATH=./data/registry.db

# Persistent signing key path (auto-generated on first boot)
SIGNING_KEY_PATH=./data/signing.pem

# Encryption key for AES-256-GCM (hex, 64 chars = 32 bytes)
VFACE_ENCRYPTION_KEY=your_64_char_hex_key_here

# Matching service connection
MATCHING_SERVICE_URL=http://localhost:8001
MATCHING_SECRET=change-me-in-production

# Frontend CORS origins
DASHBOARD_URL=http://localhost:5173
PLAYGROUND_URL=http://localhost:5174

# ============================================================================
# Matching Service (Python)
# ============================================================================
QDRANT_URL=http://localhost:6333
COLLECTION_NAME=vface_embeddings
VECTOR_DIM=128
SIMILARITY_THRESHOLD=0.85

# ============================================================================
# Docker Compose
# ============================================================================
# For Docker, use internal service names:
# QDRANT_URL=http://qdrant:6333
# MATCHING_SERVICE_URL=http://matching:8001

# ============================================================================
# IPFS Decentralized Storage (#5)
# ============================================================================
IPFS_PROVIDER=web3storage
# PINATA_API_KEY=your_pinata_api_key
# PINATA_API_SECRET=your_pinata_secret
# W3_DELEGATION_KEY=your_w3_delegation_key
# LOCAL_IPFS_API=http://localhost:5001

# ============================================================================
# WebAuthn MFA (#14)
# ============================================================================
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# ============================================================================
# Security Tuning
# ============================================================================
# Differential privacy noise sigma (0 = disabled)
DP_SIGMA=0.0
# Anomaly detection z-score threshold
ANOMALY_ZSCORE_THRESHOLD=3.0
# Embedding drift refresh threshold
REFRESH_THRESHOLD=0.70
